{
  "name": "agentos-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "agentos/agentos-service/src",
  "targets": {
    "check-openapi-spec": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "{projectRoot}/src/main/kotlin/**/*.kt",
        "{workspaceRoot}/agentos/openapi/agentos-openapi.yaml"
      ],
      "options": {
        "command": "./agentos-service/check-openapi-spec.sh",
        "cwd": "agentos"
      },
      "dependsOn": ["assemble"]
    },
    "generate-openapi-spec": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{workspaceRoot}/agentos/openapi/agentos-openapi.yaml"
      ],
      "options": {
        "command": "./gradlew :agentos-service:generateOpenApiDocs --no-configuration-cache",
        "cwd": "agentos"
      },
      "dependsOn": ["assemble"]
    },
    "regenerate": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "{workspaceRoot}/agentos/openapi/agentos-openapi.yaml"
      ],
      "options": {
        "command": "nx run agentos-api-client:generate-client"
      },
      "dependsOn": ["generate-openapi-spec"]
    },
    "bootRun": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "./gradlew :agentos-service:bootRun",
        "cwd": "agentos"
      }
    },
    "bootJar": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/build.gradle.kts",
        "{workspaceRoot}/agentos/gradle.properties",
        "{workspaceRoot}/agentos/settings.gradle.kts"
      ],
      "outputs": ["{projectRoot}/build/libs"],
      "options": {
        "command": "./gradlew :agentos-service:bootJar",
        "cwd": "agentos"
      },
      "dependsOn": ["assemble"]
    }
  },
  "tags": [
    "type:app",
    "platform:jvm",
    "scope:service"
  ]
}
